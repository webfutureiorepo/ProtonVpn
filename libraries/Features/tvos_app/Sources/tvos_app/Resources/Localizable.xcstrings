        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce nu a mers bine? Dacă ați primit un mesaj de eroare, spuneți-ne care este acesta."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čo sa pokazilo? Ak ste dostali chybovú správu, dajte nám vedieť, čo sa v nej píše."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaj se je zgodilo narobe? Če ste prejeli sporočilo o napaki, nam sporočite, kaj je pisalo."
