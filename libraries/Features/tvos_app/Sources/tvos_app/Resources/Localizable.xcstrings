    "Proton VPN for Apple TV is available on all paid plans. You can check and manage your subscription on our website." : {
      "comment" : "Subtitle of the free upsell. Appears when a free user tries to log in to the tv app.",
      "extractionState" : "manual",
      "localizations" : {
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN для Apple TV даступны на ўсіх платных тарыфных планах. Вы можаце праверыць і кіраваць сваёй падпіскай на нашым вэб-сайце."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN per a Apple TV està disponible en tots els plans de pagament. Podeu consultar i gestionar la vostra subscripció al nostre lloc web."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN pro Apple TV je k dispozici ve všech placených tarifech. Své předplatné si můžete zkontrolovat a spravovat na našich webových stránkách."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN til Apple TV er tilgængelig på alle betalte abonnementer. Du kan se og håndtere dit abonnement på vores websted."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN für Apple TV ist für alle kostenpflichtigen Abonnements verfügbar. Du kannst dein Abonnement auf unserer Website überprüfen und verwalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Proton VPN για Apple TV είναι διαθέσιμο σε όλα τα πλάνα επί πληρωμή. Μπορείτε να ελέγξετε και να διαχειριστείτε τη συνδρομή σας στον ιστότοπό μας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN for Apple TV is available on all paid plans. You can check and manage your subscription on our website."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
