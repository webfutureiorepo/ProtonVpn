        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak máte problémy s používaním služby Proton VPN, náš tím zákazníckej podpory vám rád pomôže.\n\nStačí naskenovať QR kód alebo prejsť na stránku"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du har problem med att använda Proton VPN hjälper vårt kundsupportteam gärna till.\n\nSkanna bara QR-koden eller gå till"
