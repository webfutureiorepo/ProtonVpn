          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odwiedź nasze centrum pomocy dla wskazówek, poradników i odpowiedzi na najczęściej zadawane pytania."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulte o nosso centro de ajuda online para dicas para resolver problemas, guias de configuração, e respostas para perguntas frequentes."
