        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proton VPN kullanırken sorun yaşıyorsanız, müşteri destek ekibimiz size yardımcı olmaktan mutluluk duyacaktır.\n\nQR kodunu tarayın ya da şuraya gidin"
          }
