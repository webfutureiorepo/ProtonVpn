    "Includes premium VPN protection for your mobile and desktop (connect up to 10 devices at once)" : {
      "localizations" : {
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уключае прэміяльную абарону VPN для вашай мабільнай прылады і камп'ютара (можа быць падключана да 10 прылад адначасова)"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inclou protecció VPN prèmium per al vostre mòbil i escriptori (connecteu fins a 10 dispositius alhora)"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zahrnuje prémiovou ochranu VPN pro mobilní zařízení a stolní počítače (připojení až 10 zařízení současně)"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inkluderer VPN-beskyttelse i særklasse til din mobil og computer (tilslut op til 10 enheder på én gang)"
          }
        },
        "de" : {
          "stringUnit" : {
